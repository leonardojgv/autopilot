# ─── autopilot config ────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# .env is never committed to the repository.

# GitHub token with scopes: repo, read:org
GH_TOKEN=your_github_token_here

# Optional Git identity used when the VPS repo has no local git user configured.
GIT_USER_NAME=Autopilot
GIT_USER_EMAIL=autopilot@example.com

# Base branch for all repos (can be overridden per-run with --base)
DEFAULT_BASE_BRANCH=dev

# Agent backend for the autopilot runner: claude | codex
AUTOPILOT_AGENT=codex

# Claude model to use (leave empty for default)
# Examples: claude-opus-4-8, claude-sonnet-4-6
# Model controls effort level: haiku = low, sonnet = medium, opus = high
CLAUDE_MODEL=claude-sonnet-4-6

# Codex model to use when AUTOPILOT_AGENT=codex
CODEX_MODEL=gpt-5.4

# Codex reasoning effort: low | medium | high | xhigh
CODEX_REASONING_EFFORT=medium

# Codex sandbox mode when not bypassing: read-only | workspace-write | danger-full-access
CODEX_SANDBOX_MODE=workspace-write

# Set to 1 only on hosts where bwrap sandboxing is unavailable and the machine is already isolated.
CODEX_BYPASS_SANDBOX=0

# How many clarification rounds before giving up
MAX_CLARIFICATION_ROUNDS=2

# Max minutes to wait for claude to complete (prevents VPS hangs)
CLAUDE_TIMEOUT_MINUTES=20

# Runner poll interval in minutes (used by systemd timer)
POLL_INTERVAL_MINUTES=10

# Directory where repos will be cloned
REPOS_DIR=/home/autopilot/repos

# Directory for log files
LOG_DIR=/home/autopilot/logs

# ─── repos ───────────────────────────────────────────────────────────────────
# List target repos in repos.txt (one owner/repo per line).
# Alternatively, define them here as a space-separated list:
# AUTOPILOT_REPOS="owner/repo-one owner/repo-two"
